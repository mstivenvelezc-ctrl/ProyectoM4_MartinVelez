# ─── Firebase (frontend — variables públicas de Vite) ────────────────────────
VITE_FIREBASE_API_KEY=TU_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=TU_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=TU_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=TU_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=TU_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=TU_APP_ID

# ─── AWS SES (backend — NO deben ir en el frontend) ─────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=clave_publica_usuario_IAM
AWS_SECRET_ACCESS_KEY=clave_secreta_usuario_IAM
AWS_SES_FROM_EMAIL=remitente_verificado@tudominio.com

# ─── Firebase Admin SDK (NUEVO — para verificar tokens en el servidor) ───────
# Pasos para obtenerlas:
# 1. Firebase Console → Configuración del proyecto → Cuentas de servicio
# 2. Clic en "Generar nueva clave privada" → descarga el JSON
# 3. Copia los valores del JSON aquí y en Vercel → Settings → Environment Variables
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"